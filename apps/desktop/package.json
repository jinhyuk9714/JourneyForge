{
  "name": "@journeyforge/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "pnpm --filter @journeyforge/shared build && pnpm --filter @journeyforge/core build",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pretest:e2e": "pnpm --filter @journeyforge/shared build && pnpm --filter @journeyforge/core build && pnpm build && node scripts/ensure-electron.mjs",
    "test:e2e": "playwright test -c playwright.e2e.config.ts",
    "pretest:smoke-real": "pnpm --filter @journeyforge/shared build && pnpm --filter @journeyforge/core build && pnpm build && node scripts/ensure-electron.mjs && pnpm --filter @journeyforge/core exec playwright install chromium",
    "test:smoke-real": "playwright test -c playwright.real-smoke.config.ts",
    "test": "vitest run --passWithNoTests",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@journeyforge/core": "workspace:*",
    "@journeyforge/shared": "workspace:*",
    "keytar": "^7.9.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^36.3.1",
    "electron-vite": "^3.1.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
