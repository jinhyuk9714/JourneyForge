{
  "name": "@journeyforge/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:smoke": "vitest run src/**/*.smoke.test.ts",
    "check-types": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@journeyforge/shared": "workspace:*",
    "playwright": "^1.52.0"
  }
}
