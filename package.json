{
  "name": "journeyforge",
  "private": true,
  "version": "0.1.0",
  "description": "브라우저 여정을 Playwright 테스트, API 흐름 문서, k6 초안으로 바꾸는 로컬 우선 워크스페이스",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "pnpm --filter @journeyforge/desktop dev",
    "demo-target": "node apps/demo-target/server.mjs",
    "install:browsers": "pnpm --filter @journeyforge/core exec playwright install chromium",
    "smoke": "pnpm --filter @journeyforge/core test:smoke",
    "build": "turbo run build",
    "test": "turbo run test",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
